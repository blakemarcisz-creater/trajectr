{
  "name": "trajectr",
  "version": "1.0.0",
  "description": "TrajectR — baseball hitting metrics from a Garmin Approach R10",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blakemarcisz-creater/trajectr.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/main.js --bundle --outfile=www/js/bundle.js",
